# The GIF at the top of the README. Regenerate with:
#   vhs-rs examples/readme.tape
Output examples/readme.gif

Set Width 700
Set Height 420
Set FontSize 15
Set Theme "Catppuccin Mocha"
Set WindowBar Colorful
Set BorderRadius 8
Set Margin 14
Set MarginFill "#7287fd"
Set TypingSpeed 40ms

Type "echo 'Welcome to vhs-rs!'"
Sleep 400ms
Enter
Wait
Sleep 800ms

Type "# no browser, no ffmpeg — just a binary"
Sleep 500ms
Enter
Wait
Sleep 1.5s
